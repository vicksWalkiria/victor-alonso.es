# Opciones del servidor
Options -Indexes

# ─── HTTPS y www canónico ─────────────────────────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On

  # 1. Forzar HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

  # 2. Forzar www
  RewriteCond %{HTTP_HOST} !^www\. [NC]
  RewriteRule ^ https://www.%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

  # 3. Eliminar doble barra
  RewriteCond %{REQUEST_URI} ^(.*)//(.*)$
  RewriteRule . %1/%2 [R=301,L]

  # 3.5. Forzar barra final (trailing slash) si no es un archivo físico
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_URI} !(.*)/$
  RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1/ [R=301,L]

  # 4. Redirigir .php → URL limpia (301 permanente)
  #    Evita tocar archivos reales como favicon.png, social.webp, etc.
  RewriteCond %{THE_REQUEST} \s/+(.+?)\.php[\s?] [NC]
  RewriteRule ^ /%1 [R=301,L]

  # 5. Reescritura interna: URL limpia → archivo .php
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME}.php -f
  RewriteRule ^(.+?)/?$ $1.php [L,QSA]
</IfModule>

# ─── Compresión Gzip ──────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE image/svg+xml application/xml
</IfModule>

# ─── Caché de assets estáticos ────────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/webp          "access plus 1 year"
  ExpiresByType image/png           "access plus 1 year"
  ExpiresByType image/jpeg          "access plus 1 year"
  ExpiresByType image/svg+xml       "access plus 1 month"
  ExpiresByType text/css            "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/x-icon        "access plus 1 year"
  ExpiresByType application/xml     "access plus 1 week"
</IfModule>

# ─── Cabeceras de seguridad ───────────────────────────────────────────────────
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set X-XSS-Protection "1; mode=block"
  # Strict-Transport-Security solo si el certificado es permanente
  # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# ─── Proteger archivos sensibles ──────────────────────────────────────────────
<FilesMatch "^\.">
  Order allow,deny
  Deny from all
</FilesMatch>

<FilesMatch "(config\.php|composer\.json|composer\.lock|\.env)$">
  Order allow,deny
  Deny from all
</FilesMatch>

# Bloquear acceso directo a /includes/
<IfModule mod_rewrite.c>
  RewriteRule ^includes/ - [F,L]
</IfModule>

# ─── Página de error personalizada (opcional) ─────────────────────────────────
# ErrorDocument 404 /404.php
